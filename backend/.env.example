# Copy to .env and fill in your keys.
LLM_PROVIDER=auto            # auto | openai | anthropic | gemini | none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Leave MONGODB_URL empty to use the bundled SQLite database.
MONGODB_URL=
MONGODB_DB_NAME=resume_builder

# --- Job search connectors (all optional; 4 keyless boards always work) ---
ADZUNA_APP_ID=            # free: https://developer.adzuna.com
ADZUNA_APP_KEY=
RAPIDAPI_KEY=             # free tier: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch (LinkedIn/Indeed/Naukri listings)
JOOBLE_API_KEY=           # free: https://jooble.org/api/about
JOBS_DEFAULT_COUNTRY=in

# --- SMTP for sending application emails (optional; Gmail = smtp.gmail.com + App Password) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

DEBUG=false
TEMPLATE_SEARCH_ENABLED=true
TEMPLATE_SEARCH_INTERVAL_MINUTES=360
