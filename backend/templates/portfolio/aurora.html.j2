<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>{{ r.name }} | Portfolio</title>
<style>
  :root { --acc: {{ accent }}; --acc2: {{ accent_light }}; --rgb: {{ accent_rgb }};
          --bg: #090c18; --text: #e9edf8; --muted: #97a0bb;
          --glass: rgba(255,255,255,0.05); --border: rgba(255,255,255,0.1); }
  * { box-sizing: border-box; margin: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif;
         overflow-x: hidden; }
  canvas#stars { position: fixed; inset: 0; z-index: 0; }
  .blob { position: fixed; border-radius: 50%; filter: blur(90px); opacity: .5; z-index: 0;
          will-change: transform; }
  .b1 { width: 46vw; height: 46vw; background: rgba(var(--rgb), .5); top: -12vw; left: -10vw;
        animation: drift1 26s ease-in-out infinite alternate; }
  .b2 { width: 34vw; height: 34vw; background: {{ accent_light }}44; bottom: -8vw; right: -6vw;
        animation: drift2 32s ease-in-out infinite alternate; }
  .b3 { width: 24vw; height: 24vw; background: #7c5fe833; top: 40vh; left: 55vw;
        animation: drift1 40s ease-in-out infinite alternate-reverse; }
  @keyframes drift1 { to { transform: translate(9vw, 12vh) scale(1.15) rotate(20deg); } }
  @keyframes drift2 { to { transform: translate(-10vw, -10vh) scale(0.9); } }
  .glowcur { position: fixed; width: 340px; height: 340px; border-radius: 50%; z-index: 0;
             background: radial-gradient(circle, rgba(var(--rgb), .16), transparent 65%);
             pointer-events: none; transform: translate(-50%,-50%); }
  main { position: relative; z-index: 1; }
  .progress { position: fixed; top: 0; left: 0; height: 3px; z-index: 80; width: 0;
              background: linear-gradient(90deg, var(--acc), var(--acc2)); }

  .hero { min-height: 100vh; display: flex; flex-direction: column; align-items: center;
          justify-content: center; text-align: center; padding: 0 6vw; }
  .avatar { width: 116px; height: 116px; border-radius: 50%; margin-bottom: 26px;
            border: 3px solid rgba(var(--rgb), .6); box-shadow: 0 0 44px rgba(var(--rgb), .35);
            object-fit: cover; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, var(--acc), var(--acc2));
            font-size: 40px; font-weight: 800; color: #fff; }
  h1 { font-size: clamp(38px, 7vw, 84px); letter-spacing: -1.5px; line-height: 1.03; }
  h1 span { background: linear-gradient(90deg, var(--acc2), var(--acc), var(--acc2));
            background-size: 200%; -webkit-background-clip: text; background-clip: text;
            -webkit-text-fill-color: transparent; animation: shimmer 5s linear infinite; }
  @keyframes shimmer { to { background-position: 200%; } }
  .tagline { color: var(--muted); font-size: clamp(15px, 2vw, 19px); margin-top: 18px; max-width: 62ch; }
  .heroctas { margin-top: 30px; display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  .btn { padding: 12px 26px; border-radius: 30px; font-weight: 650; text-decoration: none; font-size: 14.5px;
         color: #fff; background: linear-gradient(135deg, var(--acc), {{ accent_dark }});
         box-shadow: 0 8px 26px rgba(var(--rgb), .4); transition: transform .2s, box-shadow .2s; }
  .btn:hover { transform: translateY(-3px); box-shadow: 0 14px 34px rgba(var(--rgb), .55); }
  .btn.o { background: var(--glass); border: 1px solid var(--border); backdrop-filter: blur(10px); box-shadow: none; }

  section { max-width: 1020px; margin: 0 auto; padding: 12vh 6vw; }
  h2 { font-size: 14px; letter-spacing: 3px; text-transform: uppercase; color: var(--acc2); margin-bottom: 30px; }
  .fade { opacity: 0; transform: translateY(30px); transition: opacity .8s, transform .8s cubic-bezier(.2,.7,.2,1); }
  .fade.on { opacity: 1; transform: none; }
  .glass { background: var(--glass); border: 1px solid var(--border); border-radius: 20px;
           backdrop-filter: blur(16px); padding: 30px; }
  .about p { font-size: 18.5px; line-height: 1.7; color: #cdd4e8; }

  #web { width: 100%; height: 520px; display: block; cursor: grab; touch-action: none; }
  #web:active { cursor: grabbing; }
  .web-hint { text-align: center; color: var(--muted); font-size: 12.5px; margin-top: 8px; letter-spacing: 1px; }

  .tl { position: relative; padding-left: 34px; }
  .tl::before { content: ""; position: absolute; left: 9px; top: 0; bottom: 0; width: 2px;
                background: rgba(255,255,255,.1); }
  .tl .line { position: absolute; left: 9px; top: 0; width: 2px; height: 0;
              background: linear-gradient(var(--acc), var(--acc2)); box-shadow: 0 0 12px rgba(var(--rgb), .6); }
  .ev { position: relative; margin-bottom: 34px; }
  .ev::before { content: ""; position: absolute; left: -31px; top: 6px; width: 12px; height: 12px;
                border-radius: 50%; background: var(--bg); border: 3px solid var(--acc);
                box-shadow: 0 0 10px rgba(var(--rgb), .7); }
  .ev h3 { font-size: 20px; } .ev .co { color: var(--acc2); font-size: 14.5px; }
  .ev .dt { color: var(--muted); font-size: 12.5px; letter-spacing: 1px; }
  .ev ul { color: #cdd4e8; font-size: 14.5px; padding-left: 18px; margin-top: 8px; line-height: 1.6; }

  .projs { display: grid; grid-template-columns: repeat(auto-fit, minmax(330px, 1fr)); gap: 18px; align-items: start; }
  .pc { transition: transform .25s, box-shadow .25s, border-color .25s; }
  .pc:hover { transform: translateY(-7px); border-color: rgba(var(--rgb), .5);
              box-shadow: 0 18px 44px rgba(var(--rgb), .2); }
  .pc h3 { font-size: 19px; margin-bottom: 8px; }
  .pc p { color: var(--muted); font-size: 14.5px; line-height: 1.6; }
  .pc ul { margin: 10px 0 0 18px; color: #cdd4e8; font-size: 13.5px; line-height: 1.65; }
  .pc ul li { margin-bottom: 5px; }
  .pc ul li::marker { color: var(--acc2); }
  .pc .tags { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 6px; }
  .pc .tag { font-size: 12px; padding: 3px 10px; border-radius: 16px;
             background: rgba(var(--rgb), .16); color: var(--acc2); }
  .pc .plink { display: inline-block; margin-top: 13px; font-size: 13px; color: var(--acc2);
               text-decoration: none; border-bottom: 1px dashed rgba(var(--rgb), .55); }
  .pc .plink:hover { color: var(--text); border-bottom-style: solid; }

  .end { text-align: center; padding-bottom: 14vh; }
  .end h2 { text-transform: none; letter-spacing: -1px; font-size: clamp(30px, 5vw, 52px); color: var(--text); }
  footer { text-align: center; color: var(--muted); font-size: 12.5px; padding: 20px; position: relative; z-index: 1; }
  @media (prefers-reduced-motion: reduce) {
    .blob, h1 span { animation: none; }
    .fade { opacity: 1; transform: none; }
    .glowcur { display: none; }
  }
</style>
</head>
<body>
<canvas id="stars"></canvas>
<div class="blob b1"></div><div class="blob b2"></div><div class="blob b3"></div>
<div class="glowcur" id="glow"></div>
<div class="progress" id="bar"></div>

<main>
  <header class="hero">
    {% if r.photo %}<img class="avatar" src="{{ r.photo }}" alt="{{ r.name }}"/>
    {% else %}<div class="avatar">{{ initials }}</div>{% endif %}
    <h1>{{ r.name.split()[0] }} <span>{{ r.name.split()[1:] | join(' ') }}</span></h1>
    <p class="tagline">{{ r.headline }}</p>
    <div class="heroctas">
      {% if r.email %}<a class="btn" href="mailto:{{ r.email }}">✉ Contact me</a>{% endif %}
      {% if github %}<a class="btn o" href="https://{{ github | replace('https://','') }}" target="_blank">GitHub</a>{% endif %}
      {% if linkedin %}<a class="btn o" href="https://{{ linkedin | replace('https://','') }}" target="_blank">LinkedIn</a>{% endif %}
    </div>
  </header>

  {% if r.summary %}
  <section class="about">
    <h2>About</h2>
    <div class="glass fade"><p>{{ r.summary }}</p></div>
  </section>
  {% endif %}

  {% if flat_skills %}
  <section>
    <h2>Skill constellation</h2>
    <div class="glass fade" style="padding:10px 10px 18px">
      <canvas id="web"></canvas>
      <div class="web-hint">DRAG TO ROTATE · HOVER A NODE</div>
    </div>
  </section>
  {% endif %}

  {% if r.experience or r.education %}
  <section>
    <h2>Journey</h2>
    <div class="tl" id="tl"><div class="line" id="tlline"></div>
      {% for e in r.experience %}
      <div class="ev fade">
        <div class="dt">{{ e.start_date }} – {{ e.end_date or 'PRESENT' }}</div>
        <h3>{{ e.title }}</h3><div class="co">{{ e.company }}{% if e.location %} · {{ e.location }}{% endif %}</div>
        <ul>{% for b in e.bullets[:3] %}<li>{{ b }}</li>{% endfor %}</ul>
      </div>
      {% endfor %}
      {% for ed in r.education %}
      <div class="ev fade">
        <div class="dt">{{ ed.start_date }} – {{ ed.end_date }}</div>
        <h3>{{ ed.degree }}</h3><div class="co">{{ ed.institution }}{% if ed.gpa %} · GPA {{ ed.gpa }}{% endif %}</div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if r.projects %}
  <section>
    <h2>Projects</h2>
    <div class="projs">
      {% for p in r.projects %}
      <div class="glass pc fade">
        <h3>{{ p.name }}</h3>
        <p>{{ p.description }}</p>
        {% if p.bullets %}<ul>{% for b in p.bullets %}<li>{{ b }}</li>{% endfor %}</ul>{% endif %}
        <div class="tags">{% for t in p.technologies %}<span class="tag">{{ t }}</span>{% endfor %}</div>
        {% if p.link %}<a class="plink" href="{{ p.link if p.link.startswith('http') else 'https://' + p.link }}" target="_blank">view project ↗</a>{% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <section class="end fade">
    <h2>Open to what's next.</h2>
    <p class="tagline" style="margin:14px auto 26px">{{ r.location }}{% if r.phone %} · {{ r.phone }}{% endif %}</p>
    {% if r.email %}<a class="btn" href="mailto:{{ r.email }}">{{ r.email }}</a>{% endif %}
  </section>
</main>
<footer>© {{ r.name }} · built with ResuMate AI · <span style="opacity:.65">✦ psst: some stars are brighter than others. click one.</span></footer>

<script>
(function(){
  var reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---- living galaxy: drifting stars, shooting stars, secret skill-stars ---- */
  var CORE = {{ flat_skills[:8] | tojson }};
  var cv = document.getElementById('stars'), ctx = cv.getContext('2d'), stars = [], meteors = [];
  var found = {};
  function size(){ cv.width = innerWidth; cv.height = innerHeight; }
  size(); addEventListener('resize', size);
  for (var i = 0; i < 90; i++) stars.push({
    x: Math.random(), y: Math.random(),
    r: Math.random() * 1.4 + .3, tw: Math.random() * Math.PI * 2,
    depth: 0.3 + Math.random() * 0.7,           // parallax layer
    skill: i < CORE.length ? CORE[i] : null      // first N stars carry the secrets
  });
  // shuffle skill stars into random positions
  stars.sort(function(){ return Math.random() - .5; });
  function spawnMeteor(){
    var fromLeft = Math.random() < .5;
    meteors.push({
      x: fromLeft ? -60 : Math.random() * cv.width, y: fromLeft ? Math.random() * cv.height * .5 : -40,
      vx: 7 + Math.random() * 5, vy: 3.2 + Math.random() * 2.4, life: 1
    });
    setTimeout(spawnMeteor, 2800 + Math.random() * 4800);
  }
  if (!reduced) setTimeout(spawnMeteor, 1800);
  var GA = 0; // galaxy angle
  (function draw(t){
    ctx.clearRect(0, 0, cv.width, cv.height);
    if (!reduced) GA += 0.00012;                 // slow galactic rotation
    var ccx = cv.width / 2, ccy = cv.height / 2;
    stars.forEach(function(s){
      // rotate each star around the center at speed scaled by its depth
      var ang = GA * s.depth * 6;
      var dx = (s.x - .5) * cv.width, dy = (s.y - .5) * cv.height;
      var px = ccx + dx * Math.cos(ang) - dy * Math.sin(ang);
      var py = ccy + dx * Math.sin(ang) + dy * Math.cos(ang);
      s.px = px; s.py = py;
      var a = reduced ? .5 : (.3 + .5 * Math.abs(Math.sin(t / 900 + s.tw)));
      if (s.skill && !found[s.skill]) {          // secret stars: brighter, breathing
        var pulse = reduced ? 1 : (1 + .5 * Math.sin(t / 500 + s.tw));
        ctx.globalAlpha = Math.min(1, a + .35);
        ctx.fillStyle = '{{ accent_light }}';
        ctx.beginPath(); ctx.arc(px, py, (s.r + 1.6) * pulse, 0, 7); ctx.fill();
        ctx.globalAlpha = .18; ctx.beginPath(); ctx.arc(px, py, (s.r + 6) * pulse, 0, 7); ctx.fill();
      } else {
        ctx.globalAlpha = a; ctx.fillStyle = '#fff';
        ctx.beginPath(); ctx.arc(px, py, s.r, 0, 7); ctx.fill();
      }
    });
    // shooting stars with fading trails
    for (var m = meteors.length - 1; m >= 0; m--) {
      var mt = meteors[m];
      mt.x += mt.vx; mt.y += mt.vy; mt.life -= 0.012;
      if (mt.life <= 0 || mt.x > cv.width + 80 || mt.y > cv.height + 80) { meteors.splice(m, 1); continue; }
      var grad = ctx.createLinearGradient(mt.x, mt.y, mt.x - mt.vx * 14, mt.y - mt.vy * 14);
      grad.addColorStop(0, 'rgba(255,255,255,' + (0.9 * mt.life) + ')');
      grad.addColorStop(1, 'rgba({{ accent_rgb }},0)');
      ctx.strokeStyle = grad; ctx.lineWidth = 2; ctx.globalAlpha = 1;
      ctx.beginPath(); ctx.moveTo(mt.x, mt.y); ctx.lineTo(mt.x - mt.vx * 14, mt.y - mt.vy * 14); ctx.stroke();
    }
    ctx.globalAlpha = 1;
    requestAnimationFrame(draw);
  })(0);
  // click a secret star → burst + the skill pops up
  addEventListener('click', function(e){
    if (e.target.closest('a, button, input, textarea, #web, .pc')) return;
    var hit = null;
    stars.forEach(function(s){
      if (!s.skill || found[s.skill]) return;
      var dx = e.clientX - s.px, dy = e.clientY - s.py;
      if (dx * dx + dy * dy < 625) hit = s;      // 25px radius
    });
    if (!hit) return;
    found[hit.skill] = true;
    var n = Object.keys(found).length;
    for (var k = 0; k < 14; k++) meteors.push({   // burst of mini-streaks
      x: hit.px, y: hit.py,
      vx: Math.cos(k / 14 * 6.28) * (2 + Math.random() * 2),
      vy: Math.sin(k / 14 * 6.28) * (2 + Math.random() * 2), life: .5
    });
    var toast = document.createElement('div');
    toast.style.cssText = 'position:fixed;z-index:120;left:' + Math.min(hit.px, innerWidth - 240) +
      'px;top:' + Math.max(hit.py - 20, 16) + 'px;padding:12px 20px;border-radius:14px;' +
      'background:rgba(255,255,255,.08);border:1px solid rgba({{ accent_rgb }},.55);' +
      'backdrop-filter:blur(12px);color:#e9edf8;font:650 14px Segoe UI,sans-serif;' +
      'box-shadow:0 8px 30px rgba({{ accent_rgb }},.35);pointer-events:none;' +
      'transition:opacity .5s, transform 1.6s ease-out;';
    toast.innerHTML = '⭐ <b style="color:{{ accent_light }}">' + hit.skill + '</b>' +
      '<small style="opacity:.75"> · core skill · ' + n + '/' + CORE.length + ' discovered</small>' +
      (n === CORE.length ? '<br><small>🏆 you found them all. we should talk: {{ r.email }}</small>' : '');
    document.body.appendChild(toast);
    requestAnimationFrame(function(){ toast.style.transform = 'translateY(-46px)'; });
    setTimeout(function(){ toast.style.opacity = 0; }, 2300);
    setTimeout(function(){ toast.remove(); }, 3000);
  });

  var glow = document.getElementById('glow'), gx = innerWidth/2, gy = innerHeight/2, mx = gx, my = gy;
  addEventListener('mousemove', function(e){ mx = e.clientX; my = e.clientY; });
  (function follow(){
    gx += (mx - gx) * .07; gy += (my - gy) * .07;
    glow.style.left = gx + 'px'; glow.style.top = gy + 'px';
    requestAnimationFrame(follow);
  })();

  var io = new IntersectionObserver(function(es){
    es.forEach(function(e){ if (e.isIntersecting) e.target.classList.add('on'); });
  }, { threshold: 0.2 });
  document.querySelectorAll('.fade').forEach(function(el){ io.observe(el); });

  /* ---- Skill constellation: 3D spider-web with skills at the nodes ---- */
  var SKILLS = {{ flat_skills | tojson }};
  var web = document.getElementById('web');
  if (web) {
  var wctx = web.getContext('2d');
  var W, H, RX, RY, nodes = [], rotX = -0.35, rotY = 0.6, velY = 0.0035, dragging = false,
      lastX = 0, lastY = 0, mouseX = -1e4, mouseY = -1e4;
  function sizeWeb(){
    W = web.clientWidth; H = 520;
    var d = devicePixelRatio || 1;
    web.width = W * d; web.height = H * d; wctx.setTransform(d, 0, 0, d, 0, 0);
    // ellipsoid: stretch the web to fill the card's full width AND height
    RX = W * 0.46; RY = H * 0.50;
  }
  sizeWeb(); addEventListener('resize', sizeWeb);
  // place skills on a sphere (fibonacci lattice) for an even spider web
  var N = SKILLS.length;
  for (var i = 0; i < N; i++) {
    var t = (i + 0.5) / N, phi = Math.acos(1 - 2 * t), theta = Math.PI * (1 + Math.sqrt(5)) * i;
    nodes.push({ x: Math.sin(phi) * Math.cos(theta), y: Math.cos(phi),
                 z: Math.sin(phi) * Math.sin(theta), label: SKILLS[i] });
  }
  // unlabeled "dust" nodes at a smaller inner radius fill the web's interior
  for (var i = 0; i < 14; i++) {
    var t2 = (i + 0.5) / 14, phi2 = Math.acos(1 - 2 * t2), th2 = Math.PI * (1 + Math.sqrt(5)) * (i + 7.3);
    var rr = 0.55;
    nodes.push({ x: rr * Math.sin(phi2) * Math.cos(th2), y: rr * Math.cos(phi2),
                 z: rr * Math.sin(phi2) * Math.sin(th2), label: '' });
  }
  // web edges: connect each node to its 2 nearest neighbours
  var edges = [];
  nodes.forEach(function(a, i){
    var dists = nodes.map(function(b, j){
      if (i === j) return { j: j, d: 1e9 };
      var dx = a.x - b.x, dy = a.y - b.y, dz = a.z - b.z;
      return { j: j, d: dx*dx + dy*dy + dz*dz };
    }).sort(function(p, q){ return p.d - q.d; });
    for (var k = 0; k < 2; k++) {
      var j = dists[k].j;
      if (!edges.some(function(e){ return (e[0] === j && e[1] === i); })) edges.push([i, j]);
    }
  });
  web.addEventListener('pointerdown', function(e){ dragging = true; lastX = e.clientX; lastY = e.clientY; });
  addEventListener('pointerup', function(){ dragging = false; });
  addEventListener('pointermove', function(e){
    var rc = web.getBoundingClientRect();
    mouseX = e.clientX - rc.left; mouseY = e.clientY - rc.top;
    if (!dragging) return;
    rotY += (e.clientX - lastX) * 0.005; rotX += (e.clientY - lastY) * 0.005;
    rotX = Math.max(-1.4, Math.min(1.4, rotX));
    lastX = e.clientX; lastY = e.clientY;
  });
  function project(n){
    var cy = Math.cos(rotY), sy = Math.sin(rotY), cx = Math.cos(rotX), sx = Math.sin(rotX);
    var x1 = n.x * cy + n.z * sy, z1 = -n.x * sy + n.z * cy;
    var y2 = n.y * cx - z1 * sx, z2 = n.y * sx + z1 * cx;
    var s = 1.95 / (2.9 - z2);  // gentle perspective keeps the web spread wide
    return { x: W/2 + x1 * RX * s, y: H/2 + y2 * RY * s, z: z2, s: s };
  }
  (function spin(){
    if (!dragging && !reduced) rotY += velY;
    wctx.clearRect(0, 0, W, H);
    var pts = nodes.map(project);
    edges.forEach(function(e){
      var a = pts[e[0]], b = pts[e[1]];
      var depth = (a.z + b.z) / 2;
      wctx.strokeStyle = 'rgba({{ accent_rgb }},' + (0.10 + 0.22 * (depth + 1) / 2) + ')';
      wctx.lineWidth = 1;
      wctx.beginPath(); wctx.moveTo(a.x, a.y); wctx.lineTo(b.x, b.y); wctx.stroke();
    });
    var hover = -1, hd = 1e9;
    pts.forEach(function(p, i){
      if (!nodes[i].label) return;
      var dx = p.x - mouseX, dy = p.y - mouseY, d = dx*dx + dy*dy;
      if (d < 900 && d < hd) { hd = d; hover = i; }
    });
    pts.map(function(p, i){ return { p: p, i: i }; })
       .sort(function(a, b){ return a.p.z - b.p.z; })
       .forEach(function(o){
      var p = o.p, i = o.i, front = (p.z + 1) / 2;
      var dust = !nodes[i].label;
      wctx.fillStyle = i === hover ? '{{ accent_light }}' : 'rgba({{ accent_rgb }},' + ((dust ? 0.25 : 0.45) + 0.55 * front) + ')';
      wctx.beginPath(); wctx.arc(p.x, p.y, (i === hover ? 7 : dust ? 2 : 4) * p.s, 0, 7); wctx.fill();
      if (dust) return;
      var alpha = i === hover ? 1 : (0.3 + 0.65 * front);
      wctx.font = (i === hover ? '700 ' : '600 ') + Math.round(13 * p.s + (i === hover ? 3 : 0)) + "px 'Segoe UI', sans-serif";
      wctx.fillStyle = 'rgba(233,237,248,' + alpha + ')';
      var tw = wctx.measureText(nodes[i].label).width;
      var lx = Math.min(Math.max(p.x + 8 * p.s, 4), W - tw - 4);
      wctx.fillText(nodes[i].label, lx, Math.min(Math.max(p.y + 4, 14), H - 6));
    });
    requestAnimationFrame(spin);
  })();
  }

  var tl = document.getElementById('tl'), line = document.getElementById('tlline');
  addEventListener('scroll', function(){
    var h = document.documentElement;
    document.getElementById('bar').style.width =
      (h.scrollTop / (h.scrollHeight - h.clientHeight) * 100) + '%';
    if (tl) {
      var rc = tl.getBoundingClientRect();
      var p = Math.min(1, Math.max(0, (innerHeight * .75 - rc.top) / rc.height));
      line.style.height = (p * 100) + '%';
    }
  }, { passive: true });
})();
</script>
</body>
</html>
